# All-local mode: point the SPA at the self-hosted Supabase stack instead of Supabase Cloud.
# Copy this to web/.env.local when you want the frontend talking to the local stack:
#     cp web/.env.selfhost.example web/.env.local
#
# The ANON_KEY below is the self-host stack's DEMO key (from selfhost/.env). It is public by
# design and only safe because RLS guards every row. Regenerate real keys before any non-local use.

# Kong gateway on the local stack. The supabase-js client appends /auth/v1, /rest/v1, etc.
VITE_SUPABASE_URL=http://localhost:8000

VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Captcha is a CLOUD service (Cloudflare Turnstile) — it cannot be local. Leave unset for
# all-local mode; the widget never renders and login/register send no token.
# VITE_TURNSTILE_SITEKEY=
