# Supabase project (Project Settings -> API). Anon key is public by design.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL for invite links the admin generates (e.g. https://app.ifn.org).
# Optional: falls back to the current browser origin when unset, but set it in
# production so a link generated on a preview/localhost build still points at prod.
VITE_PUBLIC_URL=https://your-app-domain

# Cloudflare Turnstile sitekey (PUBLIC, ships in the bundle). Presence of this var turns the
# captcha widget on for login + register. Must be enabled IN LOCKSTEP with the server secret:
#   - Login   -> GoTrue captcha (Supabase Dashboard > Authentication, or GOTRUE_SECURITY_CAPTCHA_*
#                when self-hosting) with the matching Turnstile secret.
#   - Register-> the register-request edge fn's TURNSTILE_SECRET.
# Leave unset to disable captcha everywhere. Local dev: dummy always-pass key 1x00000000000000000000AA.
VITE_TURNSTILE_SITEKEY=
